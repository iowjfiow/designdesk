DATABASE_URL="postgresql://freelance:freelance@localhost:5432/freelance?schema=public"
NEXTAUTH_SECRET="change-me-in-prod-use-openssl-rand-hex-32"
NEXTAUTH_URL="http://localhost:3000"
APP_BASE_URL="http://localhost:3000"

# Payment provider toggle: stripe | razorpay
PAYMENT_PROVIDER="stripe"

# Stripe (test mode)
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_CONNECT_RETURN_URL="http://localhost:3000/dashboard/wallet?onboarded=1"
STRIPE_CONNECT_REFRESH_URL="http://localhost:3000/dashboard/wallet?refresh=1"

# Razorpay (stub)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Platform fee in basis points (10000 = 100%, 500 = 5%)
PLATFORM_FEE_BPS="0"

# Default Designer/Manager split in collab mode (must sum to <= 10000)
COLLAB_DESIGNER_BPS="6000"
COLLAB_MANAGER_BPS="4000"

# Local upload root (DEV ONLY — swap to S3 for prod)
UPLOAD_DIR="./uploads"
MAX_UPLOAD_BYTES="20971520"
